<?xml version="1.0" encoding="utf-8" ?>
<creature>
  <!--
    info - 관찰 레벨과는 관련 없는 정보들 ex)데미지, id, 이미지 소스 등
    
    observe - 관찰 정도에 따라 제공되는 정보들
              각 정보들에는 정보가 제공되는 레벨을 표기
              ex) <desc id="1" openLevel="1">"openLevel이 1일 때 이 정보가 제공됨"</desc>
              
              observe 노드 안의 level 은 관찰 단계의 갯수를 나타냄
  -->
  <info id="300105">

    <narration action="move">
      #0被指派至$0的收容單元內，開始對$0進行工作。
    </narration>
  </info>

  <observe level ="4">
    <collection>
      <codeNo openLevel ="0">T-09-94</codeNo>
      <portrait openLevel ="1">Sprites/Unit/creature/YouMusHappy</portrait>

      <name openLevel ="1">
        你必須要幸福
      </name>

      <riskLevel openLevel ="1">
        ZAYIN
      </riskLevel>

      <openText>
        許多人在這台機器中接受手術後，得到了充分休息，變得更加健康。
      </openText>

    </collection>

    <desc id="1" openLevel="0">
      [
      {一台用途不明的老舊手術機器，處處可見歲月留下的痕跡。}
      ]
    </desc>

    <desc id="2" openLevel="1">
      [
      {機器的機關在頭骨內翻攪，其設計旨在安全且有效地破壞神經組織。}
      ]
    </desc>

    <desc id="3" openLevel="2">
      [
      {許多人在這台機器中接受手術後，得到了充分休息，變得更加健康。}
      ]
    </desc>

    <desc id="4" openLevel="3">
      [
      {當被問及「你愛你的城市嗎？」時，回答「是」者，被視為病情好轉；回答「不是」者，則無法出院。}
      ]
    </desc>

    <desc id="5" openLevel="4">
      [
      {機器使用得越久，員工的狀態越佳。與此同時，使用時間越長，提問的頻率也隨之加快。}
      ]
    </desc>


    <specialTipSize size="5">
      <specialTip openLevel="1" key="1">使用該機器的員工，其所有能力數值皆會獲得提升。</specialTip>
      <specialTip openLevel="2" key="2">使用時間越長，能力值提升的幅度越高。</specialTip>
      <specialTip openLevel="2" key="3">請確認在機器頂端顯示「YES」的狀態下結束使用。若在「NO」狀態下結束，所有能力值將下降，降幅等同於先前提升的總和。</specialTip>
      <specialTip openLevel="2" key="4">提升的能力值將於次日復原。然而，曾因該對象效果累計提升超過200點能力值的員工，於當日結束時死亡。</specialTip>
      <specialTip openLevel="2" key="5">&lt;注意&gt;：我們發現，有員工在使用該異想體五次後，當場爆炸。</specialTip>
    </specialTipSize>



  </observe>
</creature>